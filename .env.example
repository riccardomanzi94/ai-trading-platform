# ============================================
# AI Trading Platform - Environment Variables
# ============================================

# Trading Configuration
# ---------------------
# Tickers to analyze (comma-separated)
# ETF list includes: Broad Market, Sector, Bonds, International, Commodities
TICKERS=SPY,QQQ,IWM,VOO,VTI,XLF,XLK,XLE,XLU,XLI,XLP,XLV,XLY,TLT,BND,AGG,LQD,VEA,VWO,GLD,USO,AAPL,MSFT,GOOGL,TSLA

# Portfolio settings
INITIAL_CAPITAL=100000
MAX_POSITION_SIZE=0.1
MAX_PORTFOLIO_RISK=0.02

# Database Configuration
# ----------------------
DATABASE_URL=postgresql://postgres:password@localhost:5432/ai_trading

# Broker Configuration (Alpaca)
# -----------------------------
ALPACA_API_KEY=your_api_key
ALPACA_SECRET_KEY=your_secret_key
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# Notifications (Optional)
# ------------------------
# Telegram
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# Slack
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx

# Email (optional)
EMAIL_SMTP_SERVER=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_USERNAME=your_email@gmail.com
EMAIL_PASSWORD=your_app_password
EMAIL_TO=recipient@example.com
